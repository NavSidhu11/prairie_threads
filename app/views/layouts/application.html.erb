<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Prairie Threads" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <!-- BOOTSTRAP CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>

  <body>

    <!-- 🔥 NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark px-3">
      <a class="navbar-brand text-white" href="/">Prairie Threads</a>

      <div class="navbar-nav">

        <%= link_to "Home", root_path, class: "nav-link text-white" %>
        <%= link_to "Products", products_path, class: "nav-link text-white" %>
        <%= link_to "Cart", cart_path, class: "nav-link text-white" %>

        <% if user_signed_in? %>
          <%= link_to "Add Address", new_address_path, class: "nav-link text-white" %>
          <%= link_to "My Orders", orders_path, class: "nav-link text-white" %>
          <span class="nav-link text-white">Hello, <%= current_user.first_name %></span>
          <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "btn btn-danger btn-sm ms-2" %>
        <% else %>
          <%= link_to "Sign Up", new_user_registration_path, class: "nav-link text-white" %>
          <%= link_to "Login", new_user_session_path, class: "nav-link text-white" %>
        <% end %>

        <% if admin_user_signed_in? %>
          <%= link_to "Admin Dashboard", admin_root_path, class: "nav-link text-warning" %>
          <%= button_to "Admin Logout", destroy_admin_user_session_path, method: :delete, class: "btn btn-warning btn-sm ms-2" %>
        <% else %>
          <%= link_to "Admin Login", new_admin_user_session_path, class: "nav-link text-white" %>
        <% end %>

      </div>
    </nav>

    <!-- 🔥 CATEGORIES -->
    <div class="container mt-3">
      <h5>Categories</h5>

      <% @categories&.each do |category| %>
        <%= link_to category.name, category_path(category), class: "me-2" %>
      <% end %>

      <%= link_to "View Cart", cart_path, class: "ms-3" %>
    </div>

    <!-- 🔥 FLASH MESSAGES -->
    <div class="container">
      <% flash.each do |type, message| %>
        <div class="alert alert-success alert-dismissible fade show mt-3">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>
    </div>

    <!-- 🔥 PAGE CONTENT -->
    <div class="container mt-4">
      <%= yield %>
    </div>

    <!-- BOOTSTRAP JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>