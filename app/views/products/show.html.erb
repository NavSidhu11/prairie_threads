<div class="container mt-4">

  <!-- Breadcrumb -->
  <p>
    <%= link_to "Home", root_path %> >

    <% if @product.categories.any? %>
      <%= link_to @product.categories.first.name, category_path(@product.categories.first) %> >
    <% end %>

    <%= @product.name %>
  </p>

  <div class="row">

    <!-- LEFT: IMAGE -->
    <div class="col-md-6">
      <% if @product.image.attached? %>
        <%= image_tag url_for(@product.image), class: "img-fluid rounded shadow" %>
      <% else %>
        <p>No Image Available</p>
      <% end %>
    </div>

    <!-- RIGHT: DETAILS -->
    <div class="col-md-6">

      <h2><%= @product.name %></h2>

      <!-- BADGES -->
      <% if @product.on_sale %>
        <span class="badge bg-danger">SALE</span>
      <% end %>

      <% if @product.created_at >= 3.days.ago %>
        <span class="badge bg-success">NEW</span>
      <% end %>

      <% if @product.updated_at >= 3.days.ago && @product.created_at < 3.days.ago %>
        <span class="badge bg-warning text-dark">UPDATED</span>
      <% end %>

      <hr>

      <p><%= @product.description %></p>

      <h3 class="text-success">$<%= @product.current_price %></h3>

      <%= button_to "Add to Cart",
          add_cart_path(product_id: @product.id),
          method: :post,
          class: "btn btn-primary btn-lg mt-3" %>

    </div>

  </div>

</div>