<%= search_form_for @q, url: products_path, method: :get do |f| %>
  <div>
    <%= f.label :name_or_description_cont, "Search" %>
    <%= f.search_field :name_or_description_cont %>
  </div>

  <div>
    <%= f.label :categories_id_eq, "Category" %>
    <%= f.collection_select :categories_id_eq, @categories, :id, :name, include_blank: "All Categories" %>
  </div>

  <%= f.submit "Search" %>
<% end %>

<div>
  <%= link_to "All", products_path %> |
  <%= link_to "On Sale", products_path(filter: 'on_sale') %> |
  <%= link_to "New", products_path(filter: 'new') %> |
  <%= link_to "Recently Updated", products_path(filter: 'recently_updated') %>
</div>

<hr>

<%= render partial: "products/product_card", collection: @products, as: :product %>

<%= paginate @products %>