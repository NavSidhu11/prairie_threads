<%= search_form_for @q, url: products_path, method: :get do |f| %>
  <div>
    <%= f.label :name_or_description_cont, "Search" %>
    <%= f.search_field :name_or_description_cont %>
  </div>

  <div>
    <%= f.label :categories_id_eq, "Category" %>
    <%= f.collection_select :categories_id_eq, @categories, :id, :name, include_blank: "All Categories" %>
  </div>

  <%= f.submit "Search" %>
<% end %>

<div>
  <%= link_to "All", products_path %> |
  <%= link_to "On Sale", products_path(filter: 'on_sale') %> |
  <%= link_to "New", products_path(filter: 'new') %> |
  <%= link_to "Recently Updated", products_path(filter: 'recently_updated') %>
</div>

<% @products.each do |product| %>
  <div style="border:1px solid #ccc; padding:10px; margin:10px;">
    
    <% if product.image.attached? %>
      <%= image_tag url_for(product.image), width: 150 %>
    <% end %>
    <% if product.on_sale %>
  <span style="background:red; color:white; padding:3px;">SALE</span>
<% end %>

<% if product.created_at >= 3.days.ago %>
  <span style="background:green; color:white; padding:3px;">NEW</span>
<% end %>

<% if product.updated_at >= 3.days.ago && product.created_at < 3.days.ago %>
  <span style="background:orange; color:white; padding:3px;">UPDATED</span>
<% end %>
    <h3><%= link_to product.name, product_path(product) %></h3>
    <p><%= product.description %></p>
    <p>$<%= product.price %></p>

  </div>
<% end %>

<%= paginate @products %>