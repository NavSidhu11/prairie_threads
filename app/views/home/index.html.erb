<div class="container mt-4">

  <!-- HERO SECTION -->
  <div class="p-5 mb-4 bg-dark text-white rounded">
    <h1 class="display-5">Welcome to Prairie Threads</h1>
    <p class="lead">Discover quality products at the best prices.</p>
    <%= link_to "Shop Now", products_path, class: "btn btn-primary btn-lg" %>
  </div>

  <!-- FEATURED PRODUCTS -->
  <h3 class="mb-3">Featured Products</h3>

  <div class="row">
    <%= render partial: "products/product_card",
        collection: @products.limit(6),
        as: :product %>
  </div>

</div>
