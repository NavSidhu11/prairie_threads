<h1>Invoice</h1>

<p><strong>Order ID:</strong> <%= @order.id %></p>
<p><strong>Status:</strong> <%= @order.status %></p>

<hr>

<h3>Products</h3>

<% @order.order_items.each do |item| %>
  <p>
  <%= item.product.name %>  
  Qty: <%= item.quantity %>  
  Price: <%= number_to_currency(item.unit_price) %>  
  Line Total: <%= number_to_currency(item.unit_price * item.quantity) %>
</p>
<% end %>

<hr>

<p><strong>Subtotal:</strong> <%= number_to_currency(@order.subtotal) %></p>

<p>GST: <%= @order.gst_rate %>%</p>
<p>PST: <%= @order.pst_rate %>%</p>
<p>HST: <%= @order.hst_rate %>%</p>

<p><strong>Tax Total:</strong> <%= number_to_currency(@order.tax_total) %></p>

<h2>Total: <%= number_to_currency(@order.grand_total) %></h2>

<hr>

<p><strong>Shipping Address:</strong></p>
<p><%= @order.address.street %>, <%= @order.address.city %></p>